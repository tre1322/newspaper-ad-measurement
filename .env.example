# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to GitHub!

# Database Configuration
DATABASE_URL=sqlite:///newspaper_ads.db

# Security Configuration
SECRET_KEY=your-secret-key-here-change-this
LOGIN_PASSWORD=your-secure-password-here

# Claude Vision ad/editorial judge (ad_judge.py)
# Required for automatic ad pre-marking on upload. Set in Railway secrets too.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Judging model. Opus 4.8 = best accuracy; set to claude-sonnet-4-6 for lower
# cost/latency. Changing this re-judges crops (the cache key includes the model).
AD_JUDGE_MODEL=claude-opus-4-8
# Set to 1 to classify every candidate as AD offline (no API calls) for testing.
AD_JUDGE_MOCK=0
# Hard cap on Claude API calls per paper (each call judges up to 4 crops).
AD_JUDGE_MAX_CALLS_PER_PAPER=500

# Google Vision (optional logo detector). Path to service-account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# Railway Environment (automatically set by Railway)
# RAILWAY_ENVIRONMENT=production